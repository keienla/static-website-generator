include ../components/navigation.pug
<!DOCTYPE html>
html(lang=language, dir=dir, itemscope, itemtype="https://schema.org/WebPage", prefix="og:http://ogp.me/ns#")
    head
        include ../components/head.pug
        meta(http-equiv="refresh", content="10;URL=./")
    body.animate-in
        header
            a(href="#main-content", class="main-content-link")
                = page.main_content_link[language]
            +navigation(page.navigation, isDefaultLanguage, language)
            +switch-language(languages, language, defaultLanguage, page.language_navigation, currentPageName, currentPageFolder)
            h1
                != page.content.title[language]
        main
            section
        footer
            p
                = page.footer.createdBy[language]
                a(href="https://github.com/keienla", target="_blank") Thibault Meyer